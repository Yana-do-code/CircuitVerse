<%= form_with(model: [@group, subgroup], local: true) do |form| %>
  <% if subgroup.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% subgroup.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, t("subgroups.form.name_label"), class: "form-label" %>
    <%= form.text_field :name, class: "form-control",
                               placeholder: t("subgroups.form.name_placeholder") %>
  </div>

  <div class="d-flex">
    <%= form.submit t("save"), class: "btn primary-button" %>
  </div>
<% end %>
